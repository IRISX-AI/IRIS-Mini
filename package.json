    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "fkill": "^10.0.3",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "open": "^11.0.0",
