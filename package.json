{
  "name": "iris-mini",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "iris": "./bin/iris-mini.ts"
  },
  "scripts": {
    "dev": "nodemon -w src/server -x tsx src/server/main.ts",
    "start": "cross-env NODE_ENV=production node dist/cli.js",
    "build:ui": "vite build",
    "build:cli": "npx esbuild bin/iris-mini.ts --bundle --platform=node --format=esm --minify --banner:js=\"#!/usr/bin/env node\" --outfile=dist/cli.js",
    "release": "npm run build:ui && npm run build:cli && npm pack"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@inquirer/prompts": "^8.4.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "chalk": "^5.6.2",
    "cross-env": "^7.0.3",
    "decibri": "^3.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "fkill": "^10.0.3",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "open": "^11.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "react-toastify": "^11.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "typescript": "^5.8.3",
    "vite-express": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "nodemon": "^3.1.10",
    "tsx": "^4.21.0",
    "vite": "^6.3.3"
  }
}
